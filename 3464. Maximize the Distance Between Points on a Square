class Solution:
    def maxDistance(self, side, points, k):
        def manhattan(p1, p2):
            return abs(p1[0] - p2[0]) + abs(p1[1] - p2[1])
        
        n = len(points)
        
        def can(d):
            # try all starting points
            for i in range(n):
                chosen = [points[i]]
                
                for j in range(n):
                    if i == j:
                        continue
                    
                    ok = True
                    for p in chosen:
                        if manhattan(p, points[j]) < d:
                            ok = False
                            break
                    
                    if ok:
                        chosen.append(points[j])
                        if len(chosen) >= k:
                            return True
            
            return False
        
        left, right = 0, 2 * side
        
        while left < right:
            mid = (left + right + 1) // 2
            if can(mid):
                left = mid
            else:
                right = mid - 1
        
        return left
