from collections import defaultdict

class Solution:
    def distance(self, nums):
        n = len(nums)
        res = [0] * n
        
        mp = defaultdict(list)
        for i, num in enumerate(nums):
            mp[num].append(i)
        
        for indices in mp.values():
            prefix_sum = 0
            total_sum = sum(indices)
            k = len(indices)
            
            for i, idx in enumerate(indices):
                left = idx * i - prefix_sum
                right = (total_sum - prefix_sum - idx) - idx * (k - i - 1)
                res[idx] = left + right
                
                prefix_sum += idx
        
        return res
