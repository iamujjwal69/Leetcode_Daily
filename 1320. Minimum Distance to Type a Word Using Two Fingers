class Solution:
    def minimumDistance(self, word: str) -> int:
        def get_dist(char1, char2):
            if char1 == None: return 0
            # Convert characters to coordinates on a 6-column grid
            pos1, pos2 = ord(char1) - ord('A'), ord(char2) - ord('A')
            x1, y1 = divmod(pos1, 6)
            x2, y2 = divmod(pos2, 6)
            return abs(x1 - x2) + abs(y1 - y2)

        memo = {}

        def solve(idx, other_finger):
            if idx == len(word):
                return 0
            
            state = (idx, other_finger)
            if state in memo:
                return memo[state]
            
            prev_char = word[idx - 1]
            curr_char = word[idx]
            
            # Option 1: Move the finger that just typed prev_char
            dist1 = get_dist(prev_char, curr_char) + solve(idx + 1, other_finger)
            
            # Option 2: Move the other finger (finger2)
            dist2 = get_dist(other_finger, curr_char) + solve(idx + 1, prev_char)
            
            memo[state] = min(dist1, dist2)
            return memo[state]

        # Start with the first character; the first finger is used for free.
        # The 'other' finger starts as None.
        return solve(1, None)
