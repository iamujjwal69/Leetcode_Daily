class Solution:
    def maxRotateFunction(self, nums):
        n = len(nums)
        total = sum(nums)
        
        # compute F(0)
        F = sum(i * num for i, num in enumerate(nums))
        res = F
        
        # compute all F(k)
        for k in range(1, n):
            F = F + total - n * nums[n - k]
            res = max(res, F)
        
        return res
