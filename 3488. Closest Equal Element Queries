from collections import defaultdict
from typing import List

class Solution:
    def solveQueries(self, nums: List[int], queries: List[int]) -> List[int]:
        n = len(nums)
        pos = defaultdict(list)
        
        # Store indices
        for i, num in enumerate(nums):
            pos[num].append(i)
        
        res = [-1] * n
        
        for indices in pos.values():
            k = len(indices)
            if k == 1:
                continue
            
            for i in range(k):
                curr = indices[i]
                prev = indices[i - 1]  # circular automatically
                next_ = indices[(i + 1) % k]
                
                d1 = abs(curr - prev)
                d2 = abs(curr - next_)
                
                # circular distance
                d1 = min(d1, n - d1)
                d2 = min(d2, n - d2)
                
                res[curr] = min(d1, d2)
        
        return [res[q] for q in queries]
